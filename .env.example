# ── Backend environment template ─────────────────────────────
# Copy to .env for local development.
# This file is committed — keep it free of real credentials.

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/predixa

# ── PostgreSQL (predi_qc schema) ──────────────────────────────
# Leave empty to skip — routes fall back to MongoDB / mock data.
DATABASE_URL=postgresql://user:password@localhost:5432/predixa_db

# ── JWT ───────────────────────────────────────────────────────
# Generate strong secrets for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGIN=http://localhost:3001,https://isrealman.github.io

# ── Cookie ────────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
